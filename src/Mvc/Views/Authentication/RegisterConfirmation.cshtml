@model RegisterConfirmationViewModel

@{
    ViewData["Title"] = "Confirmar email";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-md-5 text-center">

                    <div class="mb-3">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle border"
                             style="width:64px;height:64px;">
                            <span style="font-size:28px;">📩</span>
                        </div>
                    </div>

                    <h1 class="h4 mb-2">Cuenta creada correctamente</h1>

                    <p class="text-muted mb-4">
                        Para activar tu cuenta, necesitás confirmar tu email.
                    </p>

                    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                    {
                        <div class="alert alert-success text-start" role="alert">
                            @Model.SuccessMessage
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger text-start" role="alert">
                            @Model.ErrorMessage
                        </div>
                    }

                    <div class="text-start mb-4">
                        <div class="small text-muted mb-1">Correo de confirmación enviado a:</div>
                        <div class="fw-semibold">@Model.Email</div>

                        <hr />

                        <ul class="small text-muted mb-0">
                            <li>Revisá tu bandeja de entrada y también “Spam / Correo no deseado”.</li>
                            <li>El enlace de confirmación puede expirar. Si eso pasa, reenviá el correo.</li>
                        </ul>
                    </div>

                    <div class="d-grid gap-2">
                        <a asp-action="Login" class="btn btn-primary">
                            Ir a iniciar sesión
                        </a>

                        <form asp-action="ResendConfirmation" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="email" value="@Model.Email" />
                            <button type="submit" class="btn btn-outline-secondary">
                                Reenviar correo de confirmación
                            </button>
                        </form>
                    </div>

                    <div class="mt-4 small text-muted">
                        ¿Ingresaste un email incorrecto?
                        <a asp-action="Register" class="text-decoration-none">Volver a registrarme</a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>