@model RegisterConfirmationViewModel

@{
    ViewData["Title"] = "Confirmar email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-4 text-center">

            <h2 class="mb-3 text-nowrap">Revisá tu email</h2>

            <p class="text-muted mb-4">
                Te enviamos un enlace para confirmar tu cuenta.
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
            {
                <div class="alert alert-success" role="alert">
                    @Model.SuccessMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @Model.ErrorMessage
                </div>
            }

            <div class="mb-4">
                <div class="small text-muted mb-1">
                    Correo de confirmación enviado a:
                </div>
                <div class="fw-semibold">@Model.Email</div>
            </div>

            <form asp-action="ResendConfirmation" method="post" class="d-grid">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@Model.Email" />

                <button type="submit" class="btn btn-primary">
                    Reenviar correo de confirmación
                </button>
            </form>

            <div class="mt-4 small text-muted">
                ¿Ingresaste un email incorrecto?
                <a asp-action="Register" class="text-decoration-none">
                    Volver a registrarme
                </a>
            </div>

        </div>
    </div>
</div>
