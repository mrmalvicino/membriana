@model RegisterConfirmationViewModel

@{
    ViewData["Title"] = "Confirmar email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-4 text-center">

            <h2 class="mb-3 text-nowrap">
                @(Model.IsSuccess ? "Revisá tu email" : "No pudimos enviar el link")
            </h2>

            <p class="mb-4 @(Model.IsSuccess ? "text-success" : "text-danger")">
                @Model.Message
            </p>

            @if (Model.IsSuccess)
            {
                <div class="mb-4">
                    <div class="small text-muted mb-1">
                        Correo de confirmación enviado a:
                    </div>
                    <div class="fw-semibold">@Model.Email</div>
                </div>
            }
            else
            {
                <p class="small text-muted mb-4">
                    Si el problema continúa, pedí un nuevo link de confirmación.
                </p>

                <div class="d-grid gap-2">
                    <a asp-action="RegisterConfirmation" class="btn btn-primary">
                        Reintentar
                    </a>
                </div>
            }

            <form asp-action="ResendConfirmation" method="post" class="d-grid">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@Model.Email" />

                <button type="submit" class="btn btn-primary">
                    Reenviar correo de confirmación
                </button>
            </form>

            <div class="mt-4 small text-muted">
                ¿Ingresaste un email incorrecto?
                <a asp-action="Register" class="text-decoration-none">
                    Volver a registrarme
                </a>
            </div>

        </div>
    </div>
</div>
