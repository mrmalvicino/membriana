@model ResponseViewModel

@{
    ViewData["Title"] = "Confirmación de email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-4 text-center">

            <h2 class="mb-3 text-nowrap">
                @(Model.IsSuccess ? "Email confirmado" : "No pudimos confirmar tu email")
            </h2>

            <p class="mb-4 @(Model.IsSuccess ? "text-success" : "text-danger")">
                @Model.Message
            </p>

            @if (Model.IsSuccess)
            {
                <p class="small text-muted mb-4">
                    Ya podés iniciar sesión con tu cuenta.
                </p>

                <div class="d-grid">
                    <a asp-action="Login" class="btn btn-primary">
                        Iniciar sesión
                    </a>
                </div>
            }
            else
            {
                <p class="small text-muted mb-4">
                    Si el problema continúa, pedí un nuevo link de confirmación.
                </p>

                <div class="d-grid gap-2">
                    <a asp-action="RegisterConfirmation" class="btn btn-primary">
                        Reintentar
                    </a>
                </div>
            }

        </div>
    </div>
</div>
